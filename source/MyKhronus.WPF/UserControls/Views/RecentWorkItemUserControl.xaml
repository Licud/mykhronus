<UserControl x:Class="MyKhronus.WPF.UserControls.Views.RecentWorkItemUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MyKhronus.WPF.UserControls.Views"
             mc:Ignorable="d"
             d:DesignHeight="44" d:DesignWidth="800">

    <Border CornerRadius="3"
            BorderThickness="1"
            Padding="8 4"
            Margin="0 2">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#2a2a2a" />
                <Setter Property="BorderBrush" Value="#2a2a2a" />

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#333335" />
                        <Setter Property="BorderBrush" Value="#9c78bf" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     IsReadOnly="True"
                     Style="{StaticResource NormalTextBox}"
                     VerticalContentAlignment="Center"
                     Height="28"
                     Margin="0 0 8 0"
                     Text="{Binding Path=Name, Mode=OneTime}" />

            <local:ProjectPickerUserControl Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="0 0 8 0"
                                            DataContext="{Binding Path=ProjectPicker}" />

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Add to My Day"
                        Command="{Binding Path=AddToMyDay}">
                    <Image Source="/images/Add.png" Height="16" />
                </Button>

                <Button Background="Green" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Add to My Day and Start"
                        Command="{Binding Path=StartAddToMyDay}">
                    <Image Source="/images/Run.png" Height="16" />
                </Button>

                <Button Background="Red" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Delete Work Item"
                        Command="{Binding Path=Delete}">
                    <Image Source="/images/Delete.png" Height="16" />
                </Button>

            </StackPanel>
        </Grid>

    </Border>
</UserControl>
