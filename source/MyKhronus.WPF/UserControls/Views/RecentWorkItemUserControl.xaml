<UserControl x:Class="MyKhronus.WPF.UserControls.Views.RecentWorkItemUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MyKhronus.WPF.UserControls.Views"
             mc:Ignorable="d"
             d:DesignHeight="78" d:DesignWidth="800">

    <Border x:Name="RootBorder"
            CornerRadius="4"
            BorderThickness="1"
            Margin="0 3"
            SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#262528" />
                <Setter Property="BorderBrush" Value="#34313a" />

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2f2c36" />
                        <Setter Property="BorderBrush" Value="#9c78bf" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left accent rail -->
            <Border Grid.Column="0"
                    CornerRadius="4 0 0 4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#3a3543" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootBorder}" Value="True">
                                <Setter Property="Background" Value="#bb85fc" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Content: name on top, project pill underneath -->
            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="12 8 8 8">

                <TextBlock Text="{Binding Path=Name, Mode=OneTime}"
                           Foreground="#e8e6ec"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Margin="0 0 0 4" />

                <local:ProjectPickerUserControl HorizontalAlignment="Left"
                                                Width="220"
                                                DataContext="{Binding Path=ProjectPicker}" />
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8 0 8 0">

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Add to My Day"
                        Command="{Binding Path=AddToMyDay}">
                    <Image Source="/images/Add.png" Height="16" />
                </Button>

                <Button Background="Green" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Add to My Day and Start"
                        Command="{Binding Path=StartAddToMyDay}">
                    <Image Source="/images/Run.png" Height="16" />
                </Button>

                <Button Background="Red" Style="{StaticResource ActivityControlButton}"
                        ToolTip="Delete Work Item"
                        Command="{Binding Path=Delete}">
                    <Image Source="/images/Delete.png" Height="16" />
                </Button>

            </StackPanel>
        </Grid>

    </Border>
</UserControl>
