<UserControl x:Class="MyKhronus.WPF.UserControls.Views.DayEntryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MyKhronus.WPF.UserControls.Views"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="800">

    <Border Margin="0 5" CornerRadius="5">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#18161b" />

                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=IsTimerRunning}" Value="True">
                        <Setter Property="Background" Value="#251f2d" />
                        <Setter Property="BorderBrush" Value="#9c78bf" />
                        <Setter Property="BorderThickness" Value="1" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="0 0 0 25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Label Style="{StaticResource Header}"
                       Margin="10 10 0 0" Content="Work Item" />

                <TextBox Grid.Row="1" Margin="14 0 10 0"
                         Style="{StaticResource NormalTextBox}" IsReadOnly="True"
                         Text="{Binding Path=Name, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Label Style="{StaticResource Header}"
                       Margin="0 10 0 0"
                       Content="Duration" />

                <TextBox Grid.Row="1" Grid.Column="1"
                         Margin="4 0 10 0" Style="{StaticResource NormalTextBox}"
                         IsReadOnly="True" MinWidth="85" HorizontalContentAlignment="Center"
                         Text="{Binding Path=DurationDisplay, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <Label Style="{StaticResource Header}"
                       Margin="7 10 0 0"
                       Content="Add mins" />

                <TextBox Style="{StaticResource NormalTextBox}"
                         MinWidth="90" Margin="8 0 10 0" VerticalAlignment="Bottom"
                         Text="{Binding Path=AddMins, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Column="3" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0 35 0 0">

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Add}">
                    <Image Source="/images/Add.png" Height="16" />
                </Button>

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Subtract}">
                    <Image Source="/images/Subtract.png" Height="16" />
                </Button>

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Reset}">
                    <Image Source="/images/Reset.png" Height="14" />
                </Button>

                <Button Background="Green" Style="{StaticResource ActivityControlButton}" Command="{Binding StartTimer}"
                        Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource InverseBoolToVisibility}}">
                    <Image Source="/images/Run.png" Height="16" />
                </Button>

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding StopTimer}"
                        Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource BoolToVisibility}}">
                    <Image Source="/images/Pause.png" Height="16" />
                </Button>

                <Button Background="Red" Style="{StaticResource ActivityControlButton}" Command="{Binding Delete}">
                    <Image Source="/images/Delete.png" Height="16" />
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
