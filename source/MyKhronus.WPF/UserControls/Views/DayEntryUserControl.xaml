<UserControl x:Class="MyKhronus.WPF.UserControls.Views.DayEntryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MyKhronus.WPF.UserControls.Views"
             mc:Ignorable="d"
             d:DesignHeight="70" d:DesignWidth="1200">

    <Border Margin="0 4" CornerRadius="6">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ToggleTimer}" />
        </Border.InputBindings>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#18161b" />
                <Setter Property="BorderThickness" Value="3 0 0 0" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=IsTimerRunning}" Value="True">
                        <Setter Property="Background" Value="#1e1828" />
                        <Setter Property="BorderBrush" Value="#9c78bf" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Margin="12 8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Labels row -->
            <Label Style="{StaticResource Header}" Padding="0" Margin="0 0 0 0"
                   Content="Work Item" FontSize="10" Opacity="0.55" />
            <Label Grid.Column="1" Style="{StaticResource Header}" Padding="0"
                   Content="Project" FontSize="10" Opacity="0.55" />
            <Label Grid.Column="2" Style="{StaticResource Header}" Padding="0"
                   Content="Duration" FontSize="10" Opacity="0.55" />
            <Label Grid.Column="3" Style="{StaticResource Header}" Padding="0" Margin="0 0 10 0"
                   Content="Add mins" FontSize="10" Opacity="0.55" />

            <!-- Separator -->
            <Rectangle Grid.Row="1" Grid.ColumnSpan="5" Height="1" Fill="#2a2a2a" Margin="0 4" />

            <!-- Content row -->
            <TextBlock Grid.Row="2" Margin="0 0 10 0"
                       Text="{Binding Path=Name, Mode=OneWay}"
                       ToolTip="{Binding Path=Name, Mode=OneWay}"
                       Foreground="#e8e6ec"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />

            <local:ProjectPickerUserControl Grid.Row="2" Grid.Column="1"
                                            Margin="0 0 10 0"
                                            VerticalAlignment="Center"
                                            DataContext="{Binding Path=ProjectPicker}" />

            <TextBox Grid.Row="2" Grid.Column="2" Margin="0 0 10 0"
                     IsReadOnly="True" MinWidth="85" HorizontalContentAlignment="Center"
                     VerticalAlignment="Center"
                     Text="{Binding Path=DurationDisplay, Mode=OneWay}">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource NormalTextBox}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=IsTimerRunning}" Value="True">
                                <Setter Property="Foreground" Value="#9c78bf" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBox Grid.Row="2" Grid.Column="3" Margin="0 0 10 0"
                     Style="{StaticResource NormalTextBox}" MinWidth="60"
                     VerticalAlignment="Center"
                     Text="{Binding Path=AddMins, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Add}">
                    <Image Source="/images/Add.png" Height="16" />
                </Button>

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Subtract}">
                    <Image Source="/images/Subtract.png" Height="16" />
                </Button>

                <Button Background="#1ddecb" Style="{StaticResource ActivityControlButton}" Command="{Binding Reset}">
                    <Image Source="/images/Reset.png" Height="14" />
                </Button>

                <Rectangle Width="1" Height="18" Fill="#3a3a3a" Margin="6 0" VerticalAlignment="Center" />

                <Button Background="#3d8c40" Style="{StaticResource ActivityControlButton}" Command="{Binding StartTimer}"
                        Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource InverseBoolToVisibility}}">
                    <Image Source="/images/Run.png" Height="16" />
                </Button>

                <Button Background="#9c78bf" Style="{StaticResource ActivityControlButton}" Command="{Binding StopTimer}"
                        Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource BoolToVisibility}}">
                    <Image Source="/images/Pause.png" Height="16" />
                </Button>

                <Rectangle Width="1" Height="18" Fill="#3a3a3a" Margin="6 0" VerticalAlignment="Center" />

                <Button Background="#c0392b" Style="{StaticResource ActivityControlButton}" Command="{Binding Delete}">
                    <Image Source="/images/Delete.png" Height="16" />
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
