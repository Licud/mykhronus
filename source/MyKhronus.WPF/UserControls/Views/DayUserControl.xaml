<UserControl x:Class="MyKhronus.WPF.UserControls.Views.DayUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:MyKhronus.WPF.UserControls.Views"
             xmlns:local="clr-namespace:MyKhronus.WPF.UserControls.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200"
             DataContext="{Binding Source={StaticResource locator}, Path=DayUserControlViewModel}">
    <Grid Margin="15 10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Background="#1e1828" BorderBrush="#9c78bf" BorderThickness="1"
                MinHeight="50" Margin="5" CornerRadius="5">
            <Grid Margin="14 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Search icon -->
                <Viewbox Width="16" Height="16" Margin="0 0 10 0" VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Ellipse Canvas.Left="2" Canvas.Top="2" Width="14" Height="14"
                                 Stroke="#9c78bf" StrokeThickness="2" Fill="Transparent" />
                        <Line X1="14" Y1="14" X2="21" Y2="21"
                              Stroke="#9c78bf" StrokeThickness="2.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Viewbox>

                <!-- TextBox with placeholder -->
                <Grid Grid.Column="1">
                    <TextBox BorderThickness="0"
                             Background="Transparent"
                             Foreground="#e8e6ec"
                             CaretBrush="#9c78bf"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Text="{Binding Path=WorkItemFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="Filter_GotFocus" />
                    <TextBlock Text="Search work items..."
                               Foreground="#4a4a5a"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="3 0 0 0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkItemFilter}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WorkItemFilter}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Label Style="{StaticResource Header}" Content="My Day" />

            <ScrollViewer Grid.Row="1" Margin="0 0 20 0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Path=MyDay, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:DayEntryUserControl />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#18161b" BorderBrush="#2a2a3a" BorderThickness="1"
                    MinHeight="55" Margin="5" CornerRadius="5">
                <Grid Margin="12 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Date group -->
                    <StackPanel Orientation="Vertical" Margin="0 0 20 0">
                        <Label Style="{StaticResource Header}" Padding="0" Margin="0 0 0 3"
                               Content="Date" FontSize="10" Opacity="0.55" />
                        <StackPanel Orientation="Horizontal">
                            <DatePicker Style="{DynamicResource CustomDatePicker}" Width="130"
                                        VerticalContentAlignment="Center"
                                        SelectedDate="{Binding Path=SelectedDate, Mode=TwoWay}" />
                            <Button Background="#1ddecb" Margin="6 0 0 0"
                                    Style="{StaticResource ActivityControlButton}"
                                    VerticalAlignment="Center"
                                    Command="{Binding Path=PreviousDay}">
                                <Image Source="/images/Left.png" Height="16" />
                            </Button>
                            <Button Background="#1ddecb"
                                    Style="{StaticResource ActivityControlButton}"
                                    VerticalAlignment="Center"
                                    Command="{Binding Path=NextDay}">
                                <Image Source="/images/Right.png" Height="16" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Total Time group -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0 0 20 0">
                        <Label Style="{StaticResource Header}" Padding="0" Margin="0 0 0 3"
                               Content="Total Time" FontSize="10" Opacity="0.55" />
                        <TextBox Style="{StaticResource NormalTextBox}" Width="100"
                                 HorizontalContentAlignment="Center" IsReadOnly="True"
                                 Text="{Binding Path=TotalDurationDisplay, Mode=OneWay}" />
                    </StackPanel>

                    <!-- Right side: saved status + action buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom">

                        <Border CornerRadius="4" Background="#212121" Padding="10 4" Margin="0 0 12 0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Saved " Foreground="#555" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Path=LastSaveTime}" Foreground="#9c78bf"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Rectangle Width="1" Height="18" Fill="#3a3a3a" Margin="0 0 12 0" VerticalAlignment="Center" />

                        <Button Background="#3d8c40"
                                Style="{StaticResource ActivityControlButton}"
                                Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource InverseBoolToVisibility}}"
                                Command="{Binding StartTimer}">
                            <Image Source="/images/Run.png" Height="16" />
                        </Button>

                        <Button Background="#9c78bf"
                                Style="{StaticResource ActivityControlButton}"
                                Visibility="{Binding Path=IsTimerRunning, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding PauseTimer}">
                            <Image Source="/images/Pause.png" Height="16" />
                        </Button>

                        <Button Background="#1ddecb"
                                Style="{StaticResource ActivityControlButton}"
                                Command="{Binding Save}">
                            <Image Source="/images/SaveAll.png" Height="16" />
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Margin="0 0 0 5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#221d2b" CornerRadius="8" Padding="4" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ShowRecents}" Width="90" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="#bb85fc" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="12 4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecentsViewActive}" Value="True">
                                        <Setter Property="Background" Value="#bb85fc" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        Recents
                    </Button>
                    <Button Command="{Binding ShowScheduled}" Width="90" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="#bb85fc" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="12 4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScheduledViewActive}" Value="True">
                                        <Setter Property="Background" Value="#bb85fc" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        Scheduled
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0 0 0 15"
                    Background="#121212" CornerRadius="5">
                <Grid Margin="5">

                    <!-- Recents -->
                    <Grid Visibility="{Binding IsRecentsViewActive, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#acacac"
                                   Visibility="{Binding Path=Recents.HasItems, Converter={StaticResource InverseBoolToVisibility}}"
                                   Text="You currently have no recent work items." />

                        <ScrollViewer Visibility="{Binding Path=Recents.HasItems, Converter={StaticResource BoolToVisibility}}"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Path=Recents.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:RecentWorkItemUserControl />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Scheduled -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#acacac"
                               Visibility="{Binding IsScheduledViewActive, Converter={StaticResource BoolToVisibility}}"
                               Text="No scheduled tasks yet." />

                </Grid>
            </Border>

            <Label Grid.Row="2"
                   Style="{StaticResource Header}"
                   Content="New Entry" />

            <Border Grid.Row="3"
                    Background="#121212" CornerRadius="5">
                <Grid Margin="12 10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Background="#1e1828" BorderBrush="#9c78bf" BorderThickness="1"
                            CornerRadius="5" MinHeight="40">
                        <Grid Margin="12 0">
                            <TextBox BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#e8e6ec"
                                     CaretBrush="#9c78bf"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Path=NewEntryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding Path=AddNewEntry}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="Enter work item name..."
                                       Foreground="#4a4a5a"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="3 0 0 0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewEntryName}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NewEntryName}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Rectangle Grid.Row="1" Height="1" Fill="#2a2a3a" Margin="0 10 0 0" />

                    <Grid Grid.Row="2" Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <views:ProjectPickerUserControl DataContext="{Binding Path=ProjectPicker}" />

                        <Button Grid.Column="1"
                                Background="#bb85fc"
                                Margin="8 0 0 0" Width="100"
                                Content="Add"
                                Command="{Binding Path=AddNewEntry}" />

                        <Button Grid.Column="2"
                                Background="#bb85fc"
                                Margin="5 0" Width="100"
                                Content="Add and Start"
                                Command="{Binding Path=AddAndStartNewEntry}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
